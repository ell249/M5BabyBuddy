#pragma once

// Copy this file to config.h and fill in your values.
// config.h is gitignored — never commit it.

// WiFi credentials
#define WIFI_SSID        "your_ssid"
#define WIFI_PASSWORD    "your_password"

// Baby Buddy server — no trailing slash
// e.g. "http://192.168.1.50" or "http://babybuddy.local"
#define BB_BASE_URL      "http://192.168.x.x"

// API token from Baby Buddy: Settings → API Keys
#define BB_AUTH_TOKEN    "your-api-token-here"

// Child ID — set to 0 to auto-detect via API (uses first child found)
#define BB_CHILD_ID      0

// POSIX timezone string
// Australia/Sydney:  "AEST-10AEDT,M10.1.0,M4.1.0/3"
// Australia/Perth:   "AWST-8"
// UTC:               "UTC0"
// US/Eastern:        "EST5EDT,M3.2.0,M11.1.0"
#define BB_TIMEZONE      "AEST-10AEDT,M10.1.0,M4.1.0/3"

// NTP server
#define NTP_SERVER       "pool.ntp.org"

// Seconds of inactivity before the device renders the summary and deep-sleeps
#define SLEEP_TIMEOUT_S  30
